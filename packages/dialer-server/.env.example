# Twilio credentials (from Twilio console)
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_AUTH_TOKEN=
TWILIO_TWIML_APP_SID=
TWILIO_VOICE_APP_SID=

# Must match JWT_SECRET in BF-Server exactly
# Tokens issued by BF-Server are validated here using the same secret
BF_JWT_SECRET=

# Redis connection
REDIS_URL=

# CORS — include staff portal and client domains
ALLOWED_ORIGINS=https://staff.boreal.financial,https://client.boreal.financial

# Server config
NODE_ENV=production
PORT=3001
VOICE_ENABLED=true
